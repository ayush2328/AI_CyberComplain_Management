# ============================================================
# AI CYBER CRIME MANAGEMENT SYSTEM — Environment Variables
# ============================================================

# DATABASE — Railway MySQL
# Get this from Railway dashboard → Your MySQL service → Connect tab
DATABASE_URL="mysql://root:PASSWORD@HOST:PORT/railway"

# NEXTAUTH
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-this"
NEXTAUTH_URL="http://localhost:3000"
# On Vercel, set NEXTAUTH_URL to your production URL e.g. https://acms.vercel.app

# ANTHROPIC API — AI Crime Prediction
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your-key-here"
